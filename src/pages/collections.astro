---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const items = await getCollection('archive');
items.sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return a.data.title.localeCompare(b.data.title);
});

const catalogueUrl = 'http://calmview.co.uk/mht/calmview/';
---
<BaseLayout
  title="Collections"
  description="Search the Mountain Heritage Trust's online catalogue and browse our archive collections."
>
  <section class="catalogue-hero">
    <div class="catalogue-hero__inner">
      <p class="catalogue-hero__eyebrow">Online catalogue</p>
      <h1>Search our catalogue</h1>
      <p class="catalogue-hero__lead">
        Since moving to our archive at Blencathra we have catalogued a substantial
        amount of significant material documenting British climbing and mountaineering
        history. Browse the full catalogue to see what we hold.
      </p>
      <a class="button button--on-blue" href={catalogueUrl} rel="noopener">
        Explore the catalogue
      </a>
      <p class="catalogue-hero__note">
        To make an appointment to view material in person, email
        <a href="mailto:enquiries@mountain-heritage.org">enquiries@mountain-heritage.org</a>.
      </p>
    </div>
  </section>

  <section class="home-section">
    <h2>Featured collections</h2>
    <p>A selection of the standout collections held by the Trust.</p>
    <ul class="post-cards">
      {items.map((item) => (
        <li>
          <a href={`/collections/${item.id}`} class="post-card">
            {item.data.cover ? (
              <img class="post-card__image" src={item.data.cover} alt="" loading="lazy" />
            ) : (
              <span class="post-card__image post-card__image--placeholder" aria-hidden="true"></span>
            )}
            <h3>{item.data.title}</h3>
            {item.data.summary && <p class="post-card__summary">{item.data.summary}</p>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
