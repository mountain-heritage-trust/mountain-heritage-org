---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Image from '../../components/Image.astro';
import { articleSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateString = post.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const pageUrl = new URL(Astro.url.pathname, Astro.site as URL);
const schema = articleSchema(post, pageUrl, Astro.site as URL);
---
<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  ogType="article"
  ogImage={post.data.cover}
  schemas={[schema]}
  article={{
    publishedTime: post.data.date.toISOString(),
    author: post.data.author,
    section: 'News',
    tags: post.data.tags,
  }}
>
  <article class="article">
    <Breadcrumbs items={[
      { href: '/', label: 'Home' },
      { href: '/news-blog', label: 'News & Blog' },
      { label: post.data.title },
    ]} />
    {post.data.cover && (
      <Image
        src={post.data.cover}
        alt=""
        class="article-cover"
        sizes="(max-width: 720px) 100vw, 720px"
        loading="eager"
        fetchpriority="high"
      />
    )}
    <h1>{post.data.title}</h1>
    <p class="article-meta">
      <time datetime={post.data.date.toISOString()}>{dateString}</time>
      {post.data.author && <span> · {post.data.author}</span>}
    </p>
    {post.data.summary && <p class="article-summary">{post.data.summary}</p>}
    <Content />
  </article>
</BaseLayout>
