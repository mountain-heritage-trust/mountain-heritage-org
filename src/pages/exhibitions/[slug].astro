---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('exhibitions');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

let dateRange = '';
if (item.data.startDate && item.data.endDate) {
  dateRange = `${formatDate(item.data.startDate)} – ${formatDate(item.data.endDate)}`;
} else if (item.data.startDate) {
  dateRange = `From ${formatDate(item.data.startDate)}`;
}
---
<BaseLayout title={item.data.title} description={item.data.summary}>
  <article class="article">
    <h1>{item.data.title}</h1>
    {(dateRange || item.data.venue) && (
      <p class="article-meta">
        {dateRange}
        {dateRange && item.data.venue && ' · '}
        {item.data.venue}
      </p>
    )}
    {item.data.summary && <p class="article-summary">{item.data.summary}</p>}
    <Content />
  </article>
</BaseLayout>
