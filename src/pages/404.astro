---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="The page you were looking for could not be found.">
  <article class="article">
    <h1>Page not found</h1>
    <p>
      Sorry — the page you were looking for could not be found. It may have moved, or the
      link you followed might be out of date.
    </p>
    <p>
      You might want to:
    </p>
    <ul>
      <li>Return to the <a href="/">home page</a>.</li>
      <li>Browse the <a href="/news-blog">news &amp; blog</a> or <a href="/collections">collections</a>.</li>
      <li><a href="/contact">Get in touch</a> if you think this is a mistake.</li>
    </ul>
  </article>
</BaseLayout>
