---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Image from '../components/Image.astro';

const exhibitions = await getCollection('exhibitions');
exhibitions.sort((a, b) => {
  const ad = a.data.startDate?.getTime() ?? 0;
  const bd = b.data.startDate?.getTime() ?? 0;
  return bd - ad;
});

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Events & Exhibitions" description="Current and past exhibitions from the Mountain Heritage Trust.">
  <h1>Events &amp; Exhibitions</h1>
  <ul class="post-cards">
    {exhibitions.map((item) => (
      <li>
        <a href={`/exhibitions/${item.id}`} class="post-card">
          {item.data.cover ? (
            <Image
              src={item.data.cover}
              alt=""
              class="post-card__image"
              sizes="(max-width: 768px) 100vw, 400px"
            />
          ) : (
            <span class="post-card__image post-card__image--placeholder" aria-hidden="true"></span>
          )}
          <h2>{item.data.title}</h2>
          {(item.data.startDate || item.data.venue) && (
            <p class="article-meta">
              {item.data.startDate && formatDate(item.data.startDate)}
              {item.data.startDate && item.data.endDate && ` – ${formatDate(item.data.endDate)}`}
              {item.data.venue && (item.data.startDate ? ` · ${item.data.venue}` : item.data.venue)}
            </p>
          )}
          {item.data.summary && <p class="post-card__summary">{item.data.summary}</p>}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
