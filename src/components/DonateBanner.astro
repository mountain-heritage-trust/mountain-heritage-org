---
// Site-wide donation call-to-action, shown above the footer on every page
// except /donate. Included from BaseLayout — see the showDonateBanner check
// there for where it is suppressed.
---
<aside class="donate-banner" aria-label="Support Mountain Heritage Trust">
  <div class="donate-banner__inner">
    <div class="donate-banner__text">
      <h2 class="donate-banner__heading">Help preserve British mountaineering heritage</h2>
      <p class="donate-banner__message">
        Mountain Heritage Trust depends on donations to care for its archives and
        collections. Every gift helps keep these stories alive for future generations.
      </p>
    </div>
    <a href="/donate" class="donate-button donate-button--large donate-banner__button">
      Donate
    </a>
  </div>
</aside>
