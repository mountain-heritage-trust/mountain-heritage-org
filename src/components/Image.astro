---
// Image component that renders <picture> with AVIF + WebP sources for
// any image under /uploads/. Variants are generated by
// scripts/optimise-images.mjs at build/commit time and committed to
// public/uploads/optimised/.
//
// For images that don't have variants (SVGs, brand assets, missing
// files), this falls back to a plain <img> with the original src.
//
// Includes intrinsic width/height from the manifest so browsers can
// reserve space and avoid layout shift.

import manifest from '../../public/uploads/optimised/manifest.json';

type Manifest = Record<string, { width: number; height: number } | undefined>;
const m = manifest as Manifest;

interface Props {
  src: string;
  alt: string;
  class?: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  /** Override intrinsic dimensions (else read from manifest). */
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  class: className,
  sizes = '(max-width: 768px) 100vw, 1280px',
  loading = 'lazy',
  fetchpriority,
  width,
  height,
} = Astro.props;

const match = src.match(/^\/uploads\/([^/]+)\.(jpe?g|png)$/i);
const stem = match ? match[1] : null;
const sourceFile = match ? `${match[1]}.${match[2]}` : null;
const meta = sourceFile ? m[sourceFile] : undefined;

const finalWidth = width ?? meta?.width;
const finalHeight = height ?? meta?.height;
const hasVariants = stem !== null;

const avifSrcset = stem
  ? `/uploads/optimised/${stem}-640.avif 640w, /uploads/optimised/${stem}-1280.avif 1280w`
  : '';
const webpSrcset = stem
  ? `/uploads/optimised/${stem}-640.webp 640w, /uploads/optimised/${stem}-1280.webp 1280w`
  : '';
---
{hasVariants ? (
  <picture>
    <source type="image/avif" srcset={avifSrcset} sizes={sizes} />
    <source type="image/webp" srcset={webpSrcset} sizes={sizes} />
    <img
      src={src}
      alt={alt}
      class={className}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      width={finalWidth}
      height={finalHeight}
    />
  </picture>
) : (
  <img
    src={src}
    alt={alt}
    class={className}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    width={finalWidth}
    height={finalHeight}
  />
)}
